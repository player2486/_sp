int main(int argc, char *argv[]) {
    const char *test_src = 
        "func factorial(n) {"
        "  res = 1;"
        "  i = 1;"
        "  while (i < n + 1) {"
        "    res = res * i;"
        "    i = i + 1;"
        "  }"
        "  return res;"
        "}"
        "ans = factorial(5);" // 計算 5!
        "return ans;";
    
    src = test_src;
    next_token();
    parse_program();
    vm();
    return 0;
}